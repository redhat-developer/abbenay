{
  "name": "abbenay-monorepo",
  "version": "0.0.0-dev",
  "private": true,
  "description": "Abbenay - Unified AI Daemon Monorepo",
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "node build.js",
    "build:dev": "node build.js --skip-zip --code-install",
    "build:proto": "node build.js --proto-only",
    "build:install": "node build.js --code-install",
    "build:workspaces": "npm run build --workspaces",
    "clean": "rm -rf dist .build-venv && npm run clean --workspaces",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "audit:check": "node scripts/audit-check.js",
    "check:no-query-secrets": "node scripts/check-no-query-secrets.js",
    "ci:build": "node build.js --skip-proto",
    "ci:package-python": "cd packages/python && uvx hatch build",
    "ci:publish-vscode": "node scripts/publish-vscode.js"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@vscode-elements/elements": "^2.5.1",
    "long": "^5.3.2",
    "nice-grpc": "^2.1.14",
    "nice-grpc-common": "^2.0.2",
    "protobufjs": "^8.6.6",
    "ts-proto": "^2.11.2"
  },
  "overrides": {
    "undici": "7.28.0",
    "js-yaml": "4.3.0",
    "qs": "6.15.3",
    "uuid": "11.1.1",
    "@grpc/proto-loader": {
      "protobufjs": "7.6.5"
    },
    "express@4": {
      "body-parser": "1.20.6"
    },
    "express@5": {
      "body-parser": "2.3.0"
    },
    "minimatch@3": {
      "brace-expansion": "1.1.16"
    },
    "minimatch@5": {
      "brace-expansion": "2.1.2"
    },
    "minimatch@9": {
      "brace-expansion": "2.1.2"
    },
    "minimatch@10": {
      "brace-expansion": "5.0.7"
    }
  }
}
